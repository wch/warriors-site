---
import BaseLayout from "../layouts/BaseLayout.astro";
import ClanQuiz from "../components/quiz/ClanQuiz.tsx";
---

<BaseLayout title="Find Your Clan" description="Take the Warriors personality quiz and discover which Clan you belong to!">
  <div class="bg-forest-900 text-forest-50 py-14 px-4 text-center">
    <h1 class="text-5xl font-heading font-bold mb-3">Find Your Clan</h1>
    <p class="text-base text-forest-200 max-w-[540px] mx-auto leading-relaxed">
      Take the quiz to discover which Clan you belong to.
    </p>
  </div>
  <ClanQuiz client:load />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SeriesArcSection from "../../components/books/SeriesArcSection.astro";
import { seriesArcs, getBooksByArc } from "../../data/books";
---

<BaseLayout title="Books" description="Explore all 36 books across six epic Warriors series arcs.">
  <div class="bg-forest-900 text-forest-50 py-14 px-4 text-center">
    <h1 class="text-5xl font-heading font-bold mb-3">The Books</h1>
    <p class="text-base text-forest-200 max-w-[540px] mx-auto leading-relaxed">
      Every book in the Warriors saga, organized by series arc.
    </p>
  </div>

  <div class="max-w-6xl mx-auto px-4">
    {seriesArcs
      .sort((a, b) => a.order - b.order)
      .map((arc) => (
        <SeriesArcSection arc={arc} books={getBooksByArc(arc.id)} />
      ))}
  </div>
</BaseLayout>

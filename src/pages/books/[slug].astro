---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { books, seriesArcs, getBooksByArc, getArcForBook, getCoverUrl } from "../../data/books";
import type { Book, ArcGradient } from "../../data/books";
import { url } from "../../lib/utils";

export function getStaticPaths() {
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

interface Props {
  book: Book;
}

const { book } = Astro.props;
const arc = getArcForBook(book);
const arcBooks = getBooksByArc(arc.id);
const bookIndex = arcBooks.findIndex((b) => b.slug === book.slug);
const prevBook = bookIndex > 0 ? arcBooks[bookIndex - 1] : null;
const nextBook = bookIndex < arcBooks.length - 1 ? arcBooks[bookIndex + 1] : null;
const otherBooks = arcBooks.filter((b) => b.slug !== book.slug);
const coverUrl = getCoverUrl(book.isbn, "L");

const arcGradients: Record<ArcGradient, string> = {
  thunder: "linear-gradient(135deg, oklch(0.45 0.15 60), oklch(0.30 0.13 50))",
  forest: "linear-gradient(135deg, oklch(0.42 0.12 145), oklch(0.28 0.08 145))",
  sky: "linear-gradient(135deg, oklch(0.55 0.16 230), oklch(0.30 0.14 230))",
  shadow: "linear-gradient(135deg, oklch(0.55 0.04 250), oklch(0.30 0.04 250))",
  earth: "linear-gradient(135deg, oklch(0.50 0.10 45), oklch(0.35 0.07 45))",
  river: "linear-gradient(135deg, oklch(0.45 0.18 250), oklch(0.25 0.14 250))",
};
---

<BaseLayout title={book.title} description={book.description}>
  <div class="text-white py-12 px-4 text-center" style={`background: ${arcGradients[arc.gradient]}`}>
    <span class="text-xs uppercase tracking-wider opacity-80">Arc {arc.order} &middot; {arc.name}</span>
    <h1 class="text-4xl md:text-[56px] font-heading font-bold mt-2 leading-none tracking-tight">{book.title}</h1>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex gap-8 flex-wrap items-start">
      <img
        src={coverUrl}
        alt={`Cover of ${book.title}`}
        class="w-[200px] rounded-lg shrink-0"
        style="box-shadow: 0 12px 24px rgb(0 0 0 / 0.15)"
      />
      <div class="flex-1 min-w-[280px]">
        <span class="inline-block text-xs font-medium bg-earth-100 text-earth-700 px-2.5 py-1 rounded-full mb-2">
          {arc.name}
        </span>
        <p class="text-base text-earth-700 leading-[1.7] mb-4">{book.description}</p>
        <div class="grid grid-cols-3 gap-6 text-sm mb-6">
          <div>
            <div class="text-earth-500 text-xs uppercase tracking-wider">Year</div>
            <div class="font-semibold text-forest-900 mt-1">{book.year}</div>
          </div>
          <div>
            <div class="text-earth-500 text-xs uppercase tracking-wider">Book #</div>
            <div class="font-semibold text-forest-900 mt-1">{book.bookNumber}</div>
          </div>
          <div>
            <div class="text-earth-500 text-xs uppercase tracking-wider">Protagonist</div>
            <div class="font-semibold text-forest-900 mt-1">{book.protagonist}</div>
          </div>
        </div>
        <a
          href={url("/books")}
          class="inline-flex items-center gap-2 text-sm font-bold px-6 py-2.5 bg-forest-700 text-white rounded-lg hover:bg-forest-800 transition-colors"
        >
          &larr; Back to all books
        </a>
      </div>
    </div>

    {otherBooks.length > 0 && (
      <section class="mt-12 pt-8 border-t border-earth-200">
        <h2 class="text-2xl font-heading font-bold text-forest-900 mb-6">
          More from {arc.name}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {otherBooks.map((b) => (
            <a
              href={url(`/books/${b.slug}`)}
              class="flex items-center gap-3 bg-white rounded-lg p-3 shadow-sm hover:shadow-md transition-shadow"
            >
              <img
                src={getCoverUrl(b.isbn, "S")}
                alt={`Cover of ${b.title}`}
                class="w-10 h-14 object-cover rounded shadow-sm shrink-0"
                loading="lazy"
              />
              <div>
                <span class="text-xs text-earth-500">Book {b.bookNumber}</span>
                <h3 class="text-sm font-heading font-bold text-forest-900 mt-0.5">{b.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

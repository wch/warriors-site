---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { books, seriesArcs, getBooksByArc, getArcForBook, getCoverUrl } from "../../data/books";
import type { Book } from "../../data/books";
import { url } from "../../lib/utils";

export function getStaticPaths() {
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

interface Props {
  book: Book;
}

const { book } = Astro.props;
const arc = getArcForBook(book);
const arcBooks = getBooksByArc(arc.id);
const bookIndex = arcBooks.findIndex((b) => b.slug === book.slug);
const prevBook = bookIndex > 0 ? arcBooks[bookIndex - 1] : null;
const nextBook = bookIndex < arcBooks.length - 1 ? arcBooks[bookIndex + 1] : null;
const otherBooks = arcBooks.filter((b) => b.slug !== book.slug);

const arcGradients: Record<string, string> = {
  "the-prophecies-begin": "from-amber-700 to-amber-900",
  "the-new-prophecy": "from-forest-600 to-forest-800",
  "power-of-three": "from-sky-600 to-sky-800",
  "omen-of-the-stars": "from-slate-600 to-slate-800",
  "a-vision-of-shadows": "from-earth-500 to-earth-700",
  "the-broken-code": "from-blue-700 to-blue-900",
};
const gradient = arcGradients[book.seriesArc] ?? "from-forest-600 to-forest-800";
const coverUrl = getCoverUrl(book.isbn, "L");
---

<BaseLayout title={book.title} description={book.description}>
  <div class={`bg-gradient-to-br ${gradient} text-white`}>
    <div class="max-w-4xl mx-auto px-4 py-12">
      <nav class="text-sm mb-6 opacity-80">
        <a href={url("/")} class="hover:underline">Home</a>
        <span class="mx-2">/</span>
        <a href={url("/books")} class="hover:underline">Books</a>
        <span class="mx-2">/</span>
        <a href={url(`/books#${arc.id}`)} class="hover:underline">{arc.name}</a>
        <span class="mx-2">/</span>
        <span>{book.title}</span>
      </nav>
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <div class="shrink-0">
          <img
            src={coverUrl}
            alt={`Cover of ${book.title}`}
            class="w-48 h-72 object-cover rounded-xl shadow-2xl"
          />
        </div>
        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-block text-xs font-medium bg-white/20 px-3 py-1 rounded-full">
              {arc.name}
            </span>
            <span class="inline-block text-xs font-medium bg-white/20 px-3 py-1 rounded-full">
              Book {book.bookNumber} of 6
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">{book.title}</h1>
          <p class="text-white/90 leading-relaxed">{book.description}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
      <div class="bg-white rounded-xl p-5 shadow-sm">
        <dt class="text-xs uppercase tracking-wider text-earth-500 mb-1">Published</dt>
        <dd class="text-forest-900 font-heading font-bold">{book.year}</dd>
      </div>
      <div class="bg-white rounded-xl p-5 shadow-sm">
        <dt class="text-xs uppercase tracking-wider text-earth-500 mb-1">Protagonist</dt>
        <dd class="text-forest-900 font-heading font-bold">{book.protagonist}</dd>
      </div>
      <div class="bg-white rounded-xl p-5 shadow-sm">
        <dt class="text-xs uppercase tracking-wider text-earth-500 mb-1">Series Arc</dt>
        <dd class="text-forest-900 font-heading font-bold">{arc.name}</dd>
      </div>
    </div>

    <nav class="flex items-center justify-between border-t border-b border-earth-200 py-4 mb-10">
      {prevBook ? (
        <a href={url(`/books/${prevBook.slug}`)} class="text-sm text-forest-700 hover:text-forest-900 transition-colors">
          &larr; {prevBook.title}
        </a>
      ) : (
        <span />
      )}
      {nextBook ? (
        <a href={url(`/books/${nextBook.slug}`)} class="text-sm text-forest-700 hover:text-forest-900 transition-colors">
          {nextBook.title} &rarr;
        </a>
      ) : (
        <span />
      )}
    </nav>

    {otherBooks.length > 0 && (
      <section>
        <h2 class="text-2xl font-heading font-bold text-forest-900 mb-6">
          More from {arc.name}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {otherBooks.map((b) => (
            <a
              href={url(`/books/${b.slug}`)}
              class="flex items-center gap-3 bg-white rounded-lg p-3 shadow-sm hover:shadow-md transition-shadow"
            >
              <img
                src={getCoverUrl(b.isbn, "S")}
                alt={`Cover of ${b.title}`}
                class="w-10 h-14 object-cover rounded shadow-sm shrink-0"
                loading="lazy"
              />
              <div>
                <span class="text-xs text-earth-500">Book {b.bookNumber}</span>
                <h3 class="text-sm font-heading font-bold text-forest-900 mt-0.5">{b.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

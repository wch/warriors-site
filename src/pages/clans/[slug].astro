---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CharacterCard from "../../components/clans/CharacterCard.astro";
import { clans } from "../../data/clans";
import { getCharactersByClan } from "../../data/characters";
import type { Clan } from "../../data/clans";
import { url } from "../../lib/utils";

export function getStaticPaths() {
  return clans.map((clan) => ({
    params: { slug: clan.slug },
    props: { clan },
  }));
}

interface Props {
  clan: Clan;
}

const { clan } = Astro.props;
const clanCharacters = getCharactersByClan(clan.slug);
const otherClans = clans.filter((c) => c.slug !== clan.slug);

const headerColors: Record<string, string> = {
  amber: "from-amber-600 to-amber-800",
  slate: "from-slate-600 to-slate-800",
  blue: "from-blue-600 to-blue-800",
  stone: "from-stone-500 to-stone-700",
  sky: "from-sky-500 to-sky-700",
};
const headerGradient = headerColors[clan.color] ?? "from-forest-600 to-forest-800";
---

<BaseLayout title={clan.name} description={`Learn about ${clan.name} — ${clan.motto}. Meet the cats, explore the territory, and discover what makes this Clan unique.`}>
  <div class={`bg-gradient-to-br ${headerGradient} text-white`}>
    <div class="max-w-4xl mx-auto px-4 py-12">
      <nav class="text-sm mb-6 opacity-80">
        <a href={url("/")} class="hover:underline">Home</a>
        <span class="mx-2">/</span>
        <a href={url("/clans")} class="hover:underline">Clans</a>
        <span class="mx-2">/</span>
        <span>{clan.name}</span>
      </nav>
      <div class="flex items-center gap-4">
        <span class="text-5xl">{clan.symbol}</span>
        <div>
          <h1 class="text-4xl md:text-5xl font-heading font-bold">{clan.name}</h1>
          <p class="text-lg italic opacity-90 mt-1">"{clan.motto}"</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-10">
    <section class="mb-10">
      <h2 class="text-2xl font-heading font-bold text-forest-900 mb-3">About</h2>
      <p class="text-earth-700 leading-relaxed text-lg">{clan.description}</p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-heading font-bold text-forest-900 mb-3">Territory</h2>
      <p class="text-earth-700 leading-relaxed">{clan.territory}</p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-heading font-bold text-forest-900 mb-3">Strengths</h2>
      <ul class="space-y-2">
        {clan.strengths.map((strength) => (
          <li class="flex items-center gap-3 text-earth-700">
            <span class="w-2 h-2 rounded-full bg-gold-500 shrink-0" />
            {strength}
          </li>
        ))}
      </ul>
    </section>

    {clanCharacters.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-heading font-bold text-forest-900 mb-6">Notable Cats</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {clanCharacters.map((character) => (
            <CharacterCard character={character} clanColor={clan.color} />
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="text-2xl font-heading font-bold text-forest-900 mb-4">Other Clans</h2>
      <div class="flex flex-wrap gap-3">
        {otherClans.map((c) => (
          <a
            href={url(`/clans/${c.slug}`)}
            class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow text-sm font-medium text-forest-700"
          >
            <span>{c.symbol}</span>
            {c.name}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

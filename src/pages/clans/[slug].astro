---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CharacterCard from "../../components/clans/CharacterCard.astro";
import { clans } from "../../data/clans";
import { getCharactersByClan } from "../../data/characters";
import type { Clan } from "../../data/clans";
import { url } from "../../lib/utils";

export function getStaticPaths() {
  return clans.map((clan) => ({
    params: { slug: clan.slug },
    props: { clan },
  }));
}

interface Props {
  clan: Clan;
}

const { clan } = Astro.props;
const clanCharacters = getCharactersByClan(clan.slug);
const otherClans = clans.filter((c) => c.slug !== clan.slug);

const clanHeroGradients: Record<string, string> = {
  thunder: "linear-gradient(135deg, oklch(0.45 0.16 60), oklch(0.25 0.13 50))",
  shadow: "linear-gradient(135deg, oklch(0.45 0.04 250), oklch(0.20 0.04 250))",
  river: "linear-gradient(135deg, oklch(0.40 0.18 250), oklch(0.20 0.14 250))",
  wind: "linear-gradient(135deg, oklch(0.55 0.02 80), oklch(0.30 0.03 80))",
  sky: "linear-gradient(135deg, oklch(0.55 0.16 230), oklch(0.25 0.14 230))",
};
const heroGradient = clanHeroGradients[clan.color] ?? clanHeroGradients.thunder;
---

<BaseLayout title={clan.name} description={`Learn about ${clan.name} — ${clan.motto}. Meet the cats, explore the territory, and discover what makes this Clan unique.`}>
  <div class="py-16 px-4 text-white text-center overflow-hidden relative" style={`background: ${heroGradient}`}>
    <span class="text-[64px] leading-none block mb-3">{clan.symbol}</span>
    <h1 class="text-[56px] font-heading font-bold leading-none tracking-tight">{clan.name}</h1>
    <p class="font-heading italic text-lg opacity-90 mt-3">"{clan.motto}"</p>
  </div>

  <div class="max-w-4xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 py-12">
      <div class="bg-white rounded-[14px] p-6 shadow-md">
        <h3 class="text-lg font-heading font-bold text-forest-900 mb-2">About</h3>
        <p class="text-sm text-earth-700 leading-relaxed">{clan.description}</p>
      </div>
      <div class="bg-white rounded-[14px] p-6 shadow-md">
        <h3 class="text-lg font-heading font-bold text-forest-900 mb-2">Territory</h3>
        <p class="text-sm text-earth-700 leading-relaxed">{clan.territory}</p>
      </div>
    </div>

    {clanCharacters.length > 0 && (
      <section class="pb-16">
        <h2 class="text-[28px] font-heading font-bold text-forest-900 mb-6 text-center">Notable Cats</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {clanCharacters.map((character) => (
            <CharacterCard character={character} clanColor={clan.color} />
          ))}
        </div>
      </section>
    )}

    <section class="pb-16">
      <h2 class="text-2xl font-heading font-bold text-forest-900 mb-4">Other Clans</h2>
      <div class="flex flex-wrap gap-3">
        {otherClans.map((c) => (
          <a
            href={url(`/clans/${c.slug}`)}
            class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow text-sm font-medium text-forest-700"
          >
            <span>{c.symbol}</span>
            {c.name}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

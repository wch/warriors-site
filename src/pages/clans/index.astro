---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ClanCard from "../../components/clans/ClanCard.astro";
import { clans } from "../../data/clans";
import { url } from "../../lib/utils";
---

<BaseLayout title="The Five Clans" description="Meet the five Clans of warrior cats — ThunderClan, ShadowClan, RiverClan, WindClan, and SkyClan.">
  <div class="bg-forest-900 text-forest-50 py-14 px-4 text-center">
    <h1 class="text-5xl font-heading font-bold mb-3">The Five Clans</h1>
    <p class="text-base text-forest-200 max-w-[540px] mx-auto leading-relaxed">
      Each Clan has its own territory, traditions, and way of life. Discover where you belong.
    </p>
  </div>

  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {clans.map((clan) => (
          <ClanCard clan={clan} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

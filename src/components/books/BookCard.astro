---
import type { Book, ArcGradient } from "../../data/books";
import { getCoverUrl, getArcForBook } from "../../data/books";
import { url } from "../../lib/utils";

interface Props {
  book: Book;
  arcName: string;
}

const { book, arcName } = Astro.props;
const arc = getArcForBook(book);

const spineGradients: Record<ArcGradient, string> = {
  thunder: "linear-gradient(180deg, oklch(0.45 0.15 60), oklch(0.30 0.13 50))",
  forest: "linear-gradient(180deg, oklch(0.42 0.12 145), oklch(0.28 0.08 145))",
  sky: "linear-gradient(180deg, oklch(0.55 0.16 230), oklch(0.30 0.14 230))",
  shadow: "linear-gradient(180deg, oklch(0.55 0.04 250), oklch(0.30 0.04 250))",
  earth: "linear-gradient(180deg, oklch(0.50 0.10 45), oklch(0.35 0.07 45))",
  river: "linear-gradient(180deg, oklch(0.45 0.18 250), oklch(0.25 0.14 250))",
};
const spineGradient = spineGradients[arc.gradient];
const coverUrl = getCoverUrl(book.isbn, "M");
---

<a href={url(`/books/${book.slug}`)} class="book-card">
  <div class="book-frame">
    <div class="book-spine" style={`background: ${spineGradient}`}></div>
    <img
      src={coverUrl}
      alt={`Cover of ${book.title}`}
      class="book-cover"
      loading="lazy"
    />
  </div>
  <div class="p-4">
    <span class="inline-block text-xs font-medium bg-earth-100 text-earth-700 px-2.5 py-1 rounded-full mb-2">
      {arcName}
    </span>
    <h3 class="text-base font-heading font-bold leading-tight text-forest-900 mb-1 book-title">
      {book.title}
    </h3>
    <p class="text-sm text-earth-600 leading-relaxed line-clamp-2">{book.description}</p>
    <div class="mt-3 flex items-center gap-1.5 text-xs text-earth-500">
      <span>{book.year}</span>
      <span>&middot;</span>
      <span>{book.protagonist}</span>
    </div>
  </div>
</a>

<style>
  .book-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.10), 0 2px 4px -2px rgb(0 0 0 / 0.10);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .book-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.10), 0 8px 10px -6px rgb(0 0 0 / 0.10);
  }
  .book-frame {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 24px 16px 18px;
    aspect-ratio: 1.4 / 1;
    overflow: hidden;
    position: relative;
    background: linear-gradient(180deg, oklch(0.97 0.02 80) 0%, oklch(0.93 0.04 75) 100%);
  }
  .book-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(circle at 20% 30%, oklch(0.85 0.08 60) 0 1px, transparent 2px),
      radial-gradient(circle at 70% 60%, oklch(0.80 0.07 55) 0 1px, transparent 2px);
    background-size: 40px 40px, 28px 28px;
    opacity: 0.4;
  }
  .book-spine {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 5px;
  }
  .book-cover {
    width: 128px;
    height: 192px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow:
      0 1px 0 rgb(0 0 0 / 0.15),
      0 12px 24px -6px rgb(0 0 0 / 0.35),
      0 4px 8px -2px rgb(0 0 0 / 0.2);
    background: var(--color-earth-100);
    transition: transform 0.35s ease;
    position: relative;
    z-index: 1;
  }
  .book-card:nth-child(odd) .book-cover { transform: rotate(-2deg); }
  .book-card:nth-child(even) .book-cover { transform: rotate(2deg); }
  .book-card:hover .book-cover { transform: rotate(0) translateY(-4px) scale(1.04); }
  .book-card:hover .book-title { color: var(--color-forest-700); }
  .book-title { transition: color 0.15s; }
</style>

---
import type { SeriesArc, Book } from "../../data/books";
import BookCard from "./BookCard.astro";

interface Props {
  arc: SeriesArc;
  books: Book[];
}

const { arc, books } = Astro.props;
---

<section id={arc.id} class="scroll-mt-20">
  <div class="mb-6">
    <span class="text-xs uppercase tracking-wider text-earth-500 font-medium">Arc {arc.order}</span>
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-forest-900 mt-1">{arc.name}</h2>
    <p class="text-earth-600 mt-2 max-w-2xl">{arc.description}</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {books.map((book) => (
      <BookCard book={book} arcName={arc.name} />
    ))}
  </div>
</section>

---
import type { SeriesArc, Book } from "../../data/books";
import BookCard from "./BookCard.astro";

interface Props {
  arc: SeriesArc;
  books: Book[];
}

const { arc, books } = Astro.props;
---

<section id={arc.id} class="arc-section scroll-mt-20">
  <div class="mb-6">
    <span class="text-xs uppercase tracking-wider text-earth-500 font-medium">Arc {arc.order}</span>
    <h2 class="text-[30px] font-heading font-bold text-forest-900 mt-1">{arc.name}</h2>
    <p class="text-[15px] text-earth-600 mt-2 max-w-3xl leading-relaxed">{arc.description}</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {books.map((book) => (
      <BookCard book={book} arcName={arc.name} />
    ))}
  </div>
</section>

<style>
  .arc-section {
    padding: 48px 0;
  }
  .arc-section + .arc-section {
    border-top: 1px solid var(--color-earth-200);
  }
</style>

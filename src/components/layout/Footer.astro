---
import { url } from "../../lib/utils";
import { warriorCode } from "../../data/warrior-code";

const year = new Date().getFullYear();
---

<footer class="bg-forest-900 text-forest-200 mt-auto">
  <div class="max-w-6xl mx-auto px-4 pt-10 pb-6">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.5fr] gap-8 md:gap-12 items-start">
      <div>
        <span class="font-display font-bold text-lg tracking-[0.12em] uppercase text-gold-400 block mb-1.5">Warriors</span>
        <p class="text-[13px] text-forest-300 leading-relaxed max-w-[280px]">
          The Warriors series is written by Erin Hunter and published by HarperCollins.
        </p>
      </div>
      <div>
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-gold-400 mb-3 inline-flex items-center gap-2">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3 L15 8 L21 9 L17 14 L18 20 L12 17 L6 20 L7 14 L3 9 L9 8 Z" /></svg>
          The Warrior Code
        </p>
        <ol class="m-0 pl-[18px] font-heading italic text-[13px] leading-[1.65] text-forest-300">
          {warriorCode.slice(0, 5).map((line) => (
            <li class="mb-1.5">{line}</li>
          ))}
        </ol>
      </div>
    </div>
    <div class="mt-7 pt-4 border-t border-forest-700 text-center text-xs text-forest-400">
      <p>&copy; {year} Warriors Fan Site. Fan-made &mdash; not affiliated with Erin Hunter or HarperCollins.</p>
    </div>
  </div>
</footer>

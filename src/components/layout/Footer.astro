---
import { url } from "../../lib/utils";
const year = new Date().getFullYear();
---

<footer class="bg-forest-900 text-forest-200 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-center md:text-left">
        <p class="font-heading text-lg text-gold-400 font-bold">Warriors</p>
        <p class="text-sm text-forest-300">
          The Warriors series is written by Erin Hunter and published by HarperCollins.
        </p>
      </div>
      <nav class="flex gap-6 text-sm">
        <a href={url("/books")} class="hover:text-gold-400 transition-colors">Books</a>
        <a href={url("/clans")} class="hover:text-gold-400 transition-colors">Clans</a>
        <a href={url("/quiz")} class="hover:text-gold-400 transition-colors">Quiz</a>
      </nav>
    </div>
    <div class="mt-6 pt-4 border-t border-forest-700 text-center text-xs text-forest-400">
      <p>&copy; {year} Warriors Fan Site. This is a fan-made site and is not affiliated with Erin Hunter or HarperCollins.</p>
    </div>
  </div>
</footer>

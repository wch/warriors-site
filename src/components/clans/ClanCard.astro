---
import type { Clan } from "../../data/clans";
import { url } from "../../lib/utils";

interface Props {
  clan: Clan;
}

const { clan } = Astro.props;

const clanColors: Record<string, { border: string; bg: string; badge: string }> = {
  amber: { border: "border-t-amber-500", bg: "bg-amber-50", badge: "bg-amber-100 text-amber-800" },
  slate: { border: "border-t-slate-500", bg: "bg-slate-50", badge: "bg-slate-100 text-slate-800" },
  blue: { border: "border-t-blue-500", bg: "bg-blue-50", badge: "bg-blue-100 text-blue-800" },
  stone: { border: "border-t-stone-400", bg: "bg-stone-50", badge: "bg-stone-100 text-stone-700" },
  sky: { border: "border-t-sky-500", bg: "bg-sky-50", badge: "bg-sky-100 text-sky-800" },
};
const colors = clanColors[clan.color] ?? clanColors.amber;
---

<a
  href={url(`/clans/${clan.slug}`)}
  class:list={[
    "group block rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 bg-white border-t-4",
    colors.border,
  ]}
>
  <div class="p-6">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">{clan.symbol}</span>
      <div>
        <h3 class="text-xl font-heading font-bold text-forest-900 group-hover:text-forest-700 transition-colors">
          {clan.name}
        </h3>
        <p class="text-sm italic text-earth-500">{clan.motto}</p>
      </div>
    </div>
    <p class="text-sm text-earth-600 leading-relaxed mb-4">{clan.description}</p>
    <div class="flex flex-wrap gap-2">
      {clan.strengths.map((strength) => (
        <span class:list={["text-xs font-medium px-2 py-1 rounded-full", colors.badge]}>
          {strength}
        </span>
      ))}
    </div>
    <p class="mt-4 text-sm font-medium text-forest-600 group-hover:text-forest-700 transition-colors">
      Meet the cats &rarr;
    </p>
  </div>
</a>

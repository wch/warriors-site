---
import type { Clan } from "../../data/clans";
import { url } from "../../lib/utils";

interface Props {
  clan: Clan;
}

const { clan } = Astro.props;

const clanHeaderGradients: Record<string, string> = {
  thunder: "linear-gradient(135deg, oklch(0.55 0.16 60), oklch(0.42 0.16 55))",
  shadow: "linear-gradient(135deg, oklch(0.40 0.05 250), oklch(0.22 0.04 250))",
  river: "linear-gradient(135deg, oklch(0.50 0.18 250), oklch(0.32 0.16 245))",
  wind: "linear-gradient(135deg, oklch(0.62 0.04 80), oklch(0.45 0.04 70))",
  sky: "linear-gradient(135deg, oklch(0.62 0.14 230), oklch(0.40 0.14 230))",
};
const headerGradient = clanHeaderGradients[clan.color] ?? clanHeaderGradients.thunder;

const strengthColors: Record<string, string> = {
  thunder: "bg-clan-thunder-soft text-[#92400e]",
  shadow: "bg-clan-shadow-soft text-[#1e293b]",
  river: "bg-clan-river-soft text-[#1e3a8a]",
  wind: "bg-clan-wind-soft text-[#44403c]",
  sky: "bg-clan-sky-soft text-[#075985]",
};
const strengthColor = strengthColors[clan.color] ?? strengthColors.thunder;
---

<a
  href={url(`/clans/${clan.slug}`)}
  class:list={["clan-card", clan.color]}
>
  <div class="clan-head" style={`background: ${headerGradient}`}>
    <span class="text-[40px] leading-none drop-shadow-md">{clan.symbol}</span>
    <div>
      <h3 class="text-[22px] font-heading font-bold text-white m-0">{clan.name}</h3>
      <p class="text-sm font-heading italic text-white/85 mt-0.5">{clan.motto}</p>
    </div>
  </div>
  <div class="p-5 pt-5 pb-6">
    <p class="text-sm text-earth-600 leading-relaxed mb-4">{clan.description}</p>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {clan.strengths.map((strength) => (
        <span class:list={["inline-flex items-center gap-1 text-xs font-medium px-2.5 py-1 rounded-full", strengthColor]}>
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><ellipse cx="6" cy="9" rx="2.2" ry="2.8"/><ellipse cx="10" cy="6" rx="2" ry="2.6"/><ellipse cx="14" cy="6" rx="2" ry="2.6"/><ellipse cx="18" cy="9" rx="2.2" ry="2.8"/><path d="M6 16 C6 12, 18 12, 18 16 C18 19, 14 21, 12 21 C10 21, 6 19, 6 16 Z"/></svg>
          {strength}
        </span>
      ))}
    </div>
    <span class="text-sm font-medium text-forest-600 transition-colors">
      Meet the cats &rarr;
    </span>
  </div>
</a>

<style>
  .clan-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.10), 0 2px 4px -2px rgb(0 0 0 / 0.10);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .clan-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.10), 0 8px 10px -6px rgb(0 0 0 / 0.10);
  }
  .clan-card:hover span:last-child {
    color: var(--color-forest-700);
  }
  .clan-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 24px;
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .clan-head::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.14;
  }
  .clan-card.thunder .clan-head::after {
    background-image: repeating-linear-gradient(45deg, #fff 0 2px, transparent 2px 14px);
  }
  .clan-card.shadow .clan-head::after {
    background-image:
      radial-gradient(circle at 20% 30%, #fff 0 2px, transparent 3px),
      radial-gradient(circle at 70% 60%, #fff 0 2px, transparent 3px),
      radial-gradient(circle at 40% 80%, #fff 0 2px, transparent 3px);
    background-size: 80px 80px, 60px 60px, 100px 100px;
    opacity: 0.10;
  }
  .clan-card.river .clan-head::after {
    background-image: repeating-linear-gradient(0deg, transparent 0 8px, #fff 8px 9px, transparent 9px 18px);
    opacity: 0.18;
  }
  .clan-card.wind .clan-head::after {
    background-image: repeating-radial-gradient(circle at 30% 50%, transparent 0 14px, #fff 14px 15px, transparent 15px 30px);
    opacity: 0.10;
  }
  .clan-card.sky .clan-head::after {
    background-image:
      radial-gradient(ellipse 40px 18px at 20% 30%, #fff 0%, transparent 60%),
      radial-gradient(ellipse 60px 22px at 70% 70%, #fff 0%, transparent 60%);
    opacity: 0.18;
  }
</style>
